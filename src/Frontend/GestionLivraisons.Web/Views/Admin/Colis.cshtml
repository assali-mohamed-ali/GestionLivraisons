@model Shared.Contracts.DTOs.PagedResult<Shared.Contracts.DTOs.ColisDto>
@{ 
    ViewData["Title"] = "Colis (Admin)";
    var livreurs = ViewBag.Livreurs as List<Shared.Contracts.DTOs.LivreurDto> ?? new();
    var clients = ViewBag.Clients as List<Shared.Contracts.DTOs.ClientDto> ?? new();

    string GetLivreurName(int? id) => id.HasValue 
        ? (livreurs.FirstOrDefault(l => l.Id == id)?.Nom ?? $"Livreur #{id}") 
        : "Non assigné";

    string GetClientName(int id) => 
        clients.FirstOrDefault(c => c.Id == id)?.Nom ?? $"Client #{id}";
}

<div class="d-flex justify-content-between mb-3">
    <h4 class="fw-bold"><i class="fas fa-boxes-stacked me-2 text-primary"></i>Colis (Admin)</h4>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addColisModal">
        <i class="fas fa-plus me-1"></i>Ajouter Colis
    </button>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>ID Colis</th><th>Libellé</th><th>Date</th><th>Montant</th><th>Poids</th><th>Livreur</th><th>Client</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var c in Model.Items)
                {
                    <tr>
                        <td><span class="badge bg-primary">#@c.Id</span></td>
                        <td>@c.Libelle</td>
                        <td>@c.DateLivraison.ToString("dd/MM/yyyy")</td>
                        <td class="fw-semibold">@c.Montant.ToString("N2") TND</td>
                        <td>@c.Poids kg</td>
                        <td><span class="badge bg-info">@GetLivreurName(c.LivreurId)</span></td>
                        <td><span class="badge bg-secondary">@GetClientName(c.ClientId)</span></td>
                        <td>
                            <form asp-action="DeleteColis" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@c.Id" />
                                <button class="btn btn-outline-danger btn-sm" onclick="return confirm('Supprimer ce colis ?');"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Ajout Colis -->
<div class="modal fade" id="addColisModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateColis" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Nouveau Colis</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2"><label class="form-label">Libellé</label><input name="Libelle" class="form-control" required /></div>
                    <div class="mb-2"><label class="form-label">Montant (TND)</label><input name="Montant" type="number" step="0.01" class="form-control" required /></div>
                    <div class="mb-2"><label class="form-label">Poids (kg)</label><input name="Poids" type="number" step="0.1" class="form-control" required /></div>
                    <div class="mb-2"><label class="form-label">Volume (m³)</label><input name="Volume" type="number" step="0.1" class="form-control" required /></div>
                    <div class="mb-2"><label class="form-label">Date Livraison</label><input name="DateLivraison" type="date" class="form-control" required /></div>
                    <div class="mb-2">
                        <label class="form-label">Client</label>
                        <select name="ClientId" class="form-select" required>
                            <option value="">Sélectionner...</option>
                            @foreach (var cl in clients) { <option value="@cl.Id">@cl.Nom @cl.Prenom</option> }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Livreur</label>
                        <select name="LivreurId" class="form-select" required>
                            <option value="">Sélectionner...</option>
                            @foreach (var l in livreurs) { <option value="@l.Id">@l.Nom @l.Prenom</option> }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary">Créer</button>
                </div>
            </form>
        </div>
    </div>
</div>
