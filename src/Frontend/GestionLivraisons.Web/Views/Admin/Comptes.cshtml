@model List<Shared.Contracts.DTOs.UserDto>
@{ ViewData["Title"] = "Comptes"; }

<h4 class="fw-bold mb-3"><i class="fas fa-user-shield me-2 text-primary"></i>Gestion des Comptes</h4>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Email</th><th>Nom</th><th>Rôle</th><th></th></tr></thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr><td>@u.Email</td><td>@u.FullName</td>
                    <td><span class="badge @(u.Role == "Admin" ? "bg-danger" : "bg-secondary")">@u.Role</span></td>
                    <td><form asp-action="DeleteCompte" method="post" class="d-inline"><input type="hidden" name="id" value="@u.Id" /><button class="btn btn-outline-danger btn-sm"><i class="fas fa-trash"></i></button></form></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
