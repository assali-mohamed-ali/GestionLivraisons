@model List<Shared.Contracts.DTOs.VehiculeDto>
@{ 
    ViewData["Title"] = "Véhicules"; 
    var livreurs = ViewBag.Livreurs as List<Shared.Contracts.DTOs.LivreurDto> ?? new();

    string GetLivreurName(int? id) => id.HasValue 
        ? (livreurs.FirstOrDefault(l => l.Id == id)?.Nom ?? $"Livreur #{id}") 
        : "Non assigné";
}

<div class="d-flex justify-content-between mb-3">
    <h4 class="fw-bold"><i class="fas fa-car me-2 text-primary"></i>Véhicules</h4>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addVehicule"><i class="fas fa-plus me-1"></i>Ajouter</button>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>ID Véhicule</th><th>Type</th><th>Matricule</th><th>Marque</th><th>Description (LSP)</th><th>Livreur Assigné</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var v in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">#@v.Id</span></td>
                        <td><span class="badge @(v.Type == "Camion" ? "bg-warning text-dark" : "bg-info")">@v.Type</span></td>
                        <td class="fw-semibold">@v.Matricule</td>
                        <td>@v.Marque</td>
                        <td class="small">@v.Description</td>
                        <td><span class="badge bg-primary">@GetLivreurName(v.LivreurId)</span></td>
                        <td>
                            <form asp-action="DeleteVehicule" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@v.Id" />
                                <button class="btn btn-outline-danger btn-sm" onclick="return confirm('Supprimer ce véhicule ?');"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="addVehicule" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <form asp-action="CreateVehicule" method="post">
        <div class="modal-header"><h5 class="modal-title">Ajouter Véhicule (Factory Pattern)</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div class="mb-2"><label class="form-label">Type</label>
                <select name="Type" id="vType" class="form-select" required><option value="Camion">Camion</option><option value="Voiture">Voiture</option></select></div>
            <div class="mb-2"><label class="form-label">Matricule</label><input name="Matricule" class="form-control" required /></div>
            <div class="mb-2"><label class="form-label">Marque</label><input name="Marque" class="form-control" required /></div>
            <div class="mb-2"><label class="form-label">Couleur</label><input name="Couleur" class="form-control" required /></div>
            <div class="mb-2"><label class="form-label">Vitesse Limite (km/h)</label><input name="VitesseLimite" type="number" class="form-control" required /></div>
            <div class="mb-2">
                <label class="form-label">Livreur</label>
                <select name="LivreurId" class="form-select" required>
                    <option value="">Sélectionner...</option>
                    @foreach (var l in livreurs) { <option value="@l.Id">@l.Nom @l.Prenom</option> }
                </select>
            </div>
            <div id="camionFields">
                <div class="mb-2"><label class="form-label">Capacité (kg)</label><input name="Capacite" type="number" step="0.1" class="form-control" /></div>
                <div class="mb-2"><label class="form-label">Nombre d'essieux</label><input name="NbrEssieux" type="number" class="form-control" /></div>
            </div>
            <div id="voitureFields" style="display:none">
                <div class="mb-2"><label class="form-label">Nombre de places</label><input name="NbrPlaces" type="number" class="form-control" /></div>
            </div>
        </div>
        <div class="modal-footer"><button class="btn btn-primary">Créer (via Factory)</button></div>
    </form>
</div></div></div>

@section Scripts {
<script>
    document.getElementById('vType').addEventListener('change', function() {
        document.getElementById('camionFields').style.display = this.value === 'Camion' ? '' : 'none';
        document.getElementById('voitureFields').style.display = this.value === 'Voiture' ? '' : 'none';
    });
</script>
}
