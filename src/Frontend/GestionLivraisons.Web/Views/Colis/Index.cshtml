@model Shared.Contracts.DTOs.PagedResult<Shared.Contracts.DTOs.ColisDto>
@{ 
    ViewData["Title"] = "Colis"; 
    var search = ViewBag.Search as Shared.Contracts.DTOs.ColisSearchParams; 
    var livreurs = ViewBag.Livreurs as List<Shared.Contracts.DTOs.LivreurDto> ?? new();
    var clients = ViewBag.Clients as List<Shared.Contracts.DTOs.ClientDto> ?? new();

    string GetLivreurName(int? id) => id.HasValue 
        ? (livreurs.FirstOrDefault(l => l.Id == id)?.Nom ?? $"Livreur #{id}") 
        : "Non assigné";

    string GetClientName(int id) => 
        clients.FirstOrDefault(c => c.Id == id)?.Nom ?? $"Client #{id}";
}

<h4 class="fw-bold mb-4"><i class="fas fa-box me-2 text-primary"></i>Recherche de Colis</h4>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label small">Libellé</label>
                <input name="libelle" class="form-control" value="@search?.Libelle" placeholder="Rechercher..." />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Montant Min</label>
                <input name="minMontant" type="number" step="0.01" class="form-control" value="@search?.MinMontant" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Montant Max</label>
                <input name="maxMontant" type="number" step="0.01" class="form-control" value="@search?.MaxMontant" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Poids Max</label>
                <input name="maxPoids" type="number" step="0.1" class="form-control" value="@search?.MaxPoids" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Date</label>
                <input name="dateLivraison" type="date" class="form-control" value="@search?.DateLivraison?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button class="btn btn-primary w-100"><i class="fas fa-search"></i></button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>ID</th><th>Libellé</th><th>Date</th><th>Montant</th><th>Poids</th><th>Livreur</th><th>Client</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Items)
                {
                    <tr>
                        <td><span class="badge bg-primary">#@c.Id</span></td>
                        <td>@c.Libelle</td>
                        <td>@c.DateLivraison.ToString("dd/MM/yyyy")</td>
                        <td class="fw-semibold">@c.Montant.ToString("N2") TND</td>
                        <td>@c.Poids kg</td>
                        <td><span class="badge bg-info">@GetLivreurName(c.LivreurId)</span></td>
                        <td><span class="badge bg-secondary">@GetClientName(c.ClientId)</span></td>
                        <td><a asp-action="Details" asp-route-id="@c.Id" class="btn btn-outline-primary btn-sm"><i class="fas fa-eye"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <span class="text-muted small">Page @Model.Page de @Model.TotalPages — @Model.TotalCount résultats</span>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i"
                           asp-route-libelle="@search?.Libelle" asp-route-minMontant="@search?.MinMontant"
                           asp-route-maxMontant="@search?.MaxMontant" asp-route-maxPoids="@search?.MaxPoids">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>
