@model Shared.Contracts.DTOs.ColisDto
@{ 
    ViewData["Title"] = $"Colis #{Model.Id}"; 
    var livreurs = ViewBag.Livreurs as List<Shared.Contracts.DTOs.LivreurDto> ?? new();
    var clients = ViewBag.Clients as List<Shared.Contracts.DTOs.ClientDto> ?? new();

    string GetLivreurName(int? id) => id.HasValue 
        ? (livreurs.FirstOrDefault(l => l.Id == id)?.Nom ?? $"Livreur #{id}") 
        : "Non assigné";

    string GetClientName(int id) => 
        clients.FirstOrDefault(c => c.Id == id)?.Nom ?? $"Client #{id}";
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3"><i class="fas fa-arrow-left me-1"></i>Retour</a>
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent"><h5 class="mb-0">@Model.Libelle</h5></div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6"><strong>Date:</strong> @Model.DateLivraison.ToString("dd/MM/yyyy")</div>
            <div class="col-md-6"><strong>Montant:</strong> @Model.Montant.ToString("N2") TND</div>
            <div class="col-md-6"><strong>Poids:</strong> @Model.Poids kg</div>
            <div class="col-md-6"><strong>Volume:</strong> @Model.Volume m³</div>
            <div class="col-md-6"><strong>Livreur:</strong> @GetLivreurName(Model.LivreurId)</div>
            <div class="col-md-6"><strong>Client:</strong> @GetClientName(Model.ClientId)</div>
        </div>
    </div>
</div>
